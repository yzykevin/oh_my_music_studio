{
  "name": "oms",
  "version": "1.1.2",
  "description": "Desktop application for analyzing local music production tools and system information",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:all": "npm run build:main && npm run build:preload",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron:dev": "npm run build:all && concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && npm run build:all && electron-builder --publish never",
    "test": "jest",
    "test:watch": "jest --watch",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "electron",
    "nextjs",
    "music",
    "daw",
    "vst"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "electron-log": "^5.0.0",
    "lucide-react": "^1.8.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.98",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.ohmyapp.musicstudio",
    "productName": "OMS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      ".next/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.music"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    }
  }
}
