{
  "name": "oh-my-music-studio",
  "version": "1.0.0",
  "description": "Desktop application for analyzing local music production tools and system information",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:all": "npm run build:main && npm run build:preload",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron:dev": "npm run build:all && concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && npm run build:all && electron-builder",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "electron",
    "nextjs",
    "music",
    "daw",
    "vst"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.0.0",
    "next": "^15.5.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.ohmyapp.musicstudio",
    "productName": "Oh My Music Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
