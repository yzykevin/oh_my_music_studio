{
  "name": "oms",
  "version": "1.1.5",
  "description": "Desktop application for analyzing local music production tools and system information",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:all": "npm run build:main && npm run build:preload",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron:dev": "npm run build:all && concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && npm run build:all && electron-builder --publish never",
    "test": "jest",
    "test:watch": "jest --watch",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "electron",
    "nextjs",
    "music",
    "daw",
    "vst"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "electron": ">=39.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.4",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.98",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^8.0.0",
    "electron": "^39.8.7",
    "electron-builder": "^26.9.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.15",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
